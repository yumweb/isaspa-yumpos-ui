# =====================================================================
# Isa Spa V2 UI — environment template. Copy to `.env` and fill in.
# =====================================================================

# Backend API. DEV: local API. PROD: https://api.isaspa.yumpos.co
REACT_APP_PUBLIC_BASE_URL=http://localhost:3000

# Must match the API's public X-API-KEY (generate a new UUID for Isa Spa)
REACT_APP_PUBLIC_API_KEY=<SUPPLY: new uuid>

# Receipt/short-URL app. PROD: https://b.isaspa.co (confirm final TLD)
REACT_APP_RECEIPT_APP_URL=http://b.isaspa.co
